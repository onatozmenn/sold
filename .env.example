# --- TCMB EVDS ---
# Ücretsiz anahtar: https://evds3.tcmb.gov.tr → Üye ol → Giriş → Profil → "API Anahtarı"
# Anahtar HTTP header'da gönderilir (URL'de değil).
EVDS_API_KEY=

# --- Veritabanı ---
# Geliştirme için SQLite yeterlidir. Üretimde PostgreSQL + PostGIS önerilir.
# Postgres örneği: postgresql+psycopg://kullanici:parola@localhost:5432/sold
DATABASE_URL=sqlite:///sold.db

# --- Scraper (saygılı toplama) ---
# Kendi iletişim bilgini yaz; site yöneticileri seni tanıyabilsin.
SCRAPER_USER_AGENT=sold-research-bot/0.1 (+academic; contact: you@example.com)
SCRAPER_MIN_DELAY=3.0
SCRAPER_MAX_DELAY=7.0
